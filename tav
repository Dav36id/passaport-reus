<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<title>Passaport Digital - Tavernes</title>

<style>
body {
  font-family: Arial, sans-serif;
  text-align: center;
  background-color: #f4f1e8;
}

h1 {
  margin-top: 20px;
  color: darkred;
}

.lloc {
  margin: 40px auto;
  padding: 20px;
  border: 2px solid #ccc;
  border-radius: 10px;
  background-color: white;
  width: 360px;
  position: relative;
}

.foto {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 10px;
}

button {
  padding: 10px 20px;
  font-size: 14px;
  background-color: darkred;
  color: white;
  border: none;
  cursor: pointer;
  margin-top: 10px;
}

.segell {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 120px;
  height: 120px;
  border: 6px solid red;
  border-radius: 50%;
  color: red;
  font-weight: bold;
  font-size: 18px;
  display: none;
  align-items: center;
  justify-content: center;
  transform: rotate(-20deg);
  background-color: rgba(255,0,0,0.1);
}
</style>
</head>

<body>

<h1>Hola Cristina! 👋</h1>
<h2>📘 Passaport Digital - Tavernes de la Valldigna</h2>

<!-- ESGLÉSIA -->
<div class="lloc">
  <div class="segell" id="segell_esglesia">VISITAT</div>
  <h2>Església Sant Josep</h2>
  <img class="foto" 
       src="https://commons.wikimedia.org/wiki/Special:FilePath/Tavernes_de_la_Valldigna_-_Església_de_Sant_Josep.jpg">
  <button onclick="comprovarUbicacio('esglesia', 'Església Sant Josep')">
    Segellar
  </button>
</div>

<!-- PARC -->
<div class="lloc">
  <div class="segell" id="segell_parc">VISITAT</div>
  <h2>Parc del Cambro</h2>
  <img class="foto" 
       src="https://commons.wikimedia.org/wiki/Special:FilePath/Tavernes_de_la_Valldigna_Parc.jpg">
  <button onclick="comprovarUbicacio('parc', 'Parc del Cambro')">
    Segellar
  </button>
</div>

<!-- MCDONALDS -->
<div class="lloc">
  <div class="segell" id="segell_mcdonalds">VISITAT</div>
  <h2>McDonald's</h2>
  <img class="foto" 
       src="https://commons.wikimedia.org/wiki/Special:FilePath/McDonald%27s_restaurant.jpg">
  <button onclick="comprovarUbicacio('mcdonalds', 'McDonald’s')">
    Segellar
  </button>
</div>

<script>

function comprovarUbicacio(clau, nomLloc) {

  if (!navigator.geolocation) {
    alert("Geolocalització no compatible");
    return;
  }

  navigator.geolocation.getCurrentPosition(function(posicio) {

    const latUsuari = posicio.coords.latitude;
    const lonUsuari = posicio.coords.longitude;

    const llocs = {

      esglesia: { lat: 39.0717, lon: -0.2644 },
      parc: { lat: 39.0724, lon: -0.2660 },
      mcdonalds: { lat: 39.0742, lon: -0.2685 }

    };

    const latLloc = llocs[clau].lat;
    const lonLloc = llocs[clau].lon;

    const distancia = calcularDistancia(
      latUsuari,
      lonUsuari,
      latLloc,
      lonLloc
    );

    if (distancia < 0.2) { // 200 metres
      desbloquejarSegell(clau);
      alert("✅ Segell desbloquejat a " + nomLloc + "!");
    } else {
      alert("❌ No estàs als 200 metres de " + nomLloc);
    }

  }, function() {
    alert("No s'ha pogut obtenir la ubicació.");
  });
}

function desbloquejarSegell(clau) {
  const segell = document.getElementById("segell_" + clau);
  segell.style.display = "flex";
  localStorage.setItem("segell_" + clau, "true");
}

function calcularDistancia(lat1, lon1, lat2, lon2) {

  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;

  const a =
    Math.sin(dLat/2) * Math.sin(dLat/2) +
    Math.cos(lat1 * Math.PI/180) *
    Math.cos(lat2 * Math.PI/180) *
    Math.sin(dLon/2) *
    Math.sin(dLon/2);

  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));

  return R * c;
}

window.onload = function() {

  ["esglesia", "parc", "mcdonalds"].forEach(function(clau) {
    if (localStorage.getItem("segell_" + clau) === "true") {
      document.getElementById("segell_" + clau).style.display = "flex";
    }
  });

};

</script>

</body>
</html>
